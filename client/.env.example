# ===========================================
# Client Environment Variables (Vite)
# ===========================================
# All variables must be prefixed with VITE_ to be exposed to the client

# -------------------------------------------
# API Configuration
# -------------------------------------------

# Backend API URL
VITE_API_URL=http://localhost:3000/api

# WebSocket server URL
VITE_SOCKET_URL=http://localhost:3000

# -------------------------------------------
# Game Configuration
# -------------------------------------------

# Betting limits (in Rs)
VITE_MIN_BET_AMOUNT=10
VITE_MAX_BET_AMOUNT=1000

# Payout multipliers
VITE_PAYOUT_NUMBER=14
VITE_PAYOUT_COLOR=2
VITE_PAYOUT_TYPE=2

# -------------------------------------------
# Timing Configuration (in seconds)
# -------------------------------------------

# Duration of the betting phase
VITE_GAME_WAITING_TIME=20

# Duration of the wheel spin animation
VITE_GAME_SPIN_DURATION=5

# Duration to display the result
VITE_GAME_RESULT_DURATION=5

# -------------------------------------------
# Animation Configuration
# -------------------------------------------

# Wheel rotation animation speed
VITE_ANIMATION_ROTATION_SPEED=15

# Number of extra spins before landing on result
VITE_ANIMATION_EXTRA_SPINS=5
