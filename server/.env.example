# ===========================================
# Server Environment Variables
# ===========================================

# -------------------------------------------
# REQUIRED - Server will not start without these
# -------------------------------------------

# Server port
#PORT=3000

# MongoDB connection string
MONGO_URL=mongodb://127.0.0.1:27017/roulette

# JWT secret for authentication (use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_change_this

# Frontend URL for CORS configuration
CLIENT_URL=http://localhost:5173

# -------------------------------------------
# OPTIONAL - Have sensible defaults
# -------------------------------------------

# Environment mode: development | production | test
# NODE_ENV=development

# Redis URL for Socket.io horizontal scaling (optional, for multi-instance deployments)
# REDIS_URL=redis://localhost:6379

# Logging level: error | warn | info | http | verbose | debug | silly
# Defaults to 'debug' in development, 'info' in production
# LOG_LEVEL=info

# -------------------------------------------
# Admin Seeding (for seedAdmin.js script)
# -------------------------------------------

# Admin account credentials for initial setup
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=your_secure_admin_password

# -------------------------------------------
# Game Configuration
# -------------------------------------------

# Game timing (in seconds)
GAME_WAITING_TIME=20
GAME_SPIN_DURATION=5
GAME_RESULT_DURATION=5

# Betting limits (in Rs)
#MIN_BET_AMOUNT=10
MAX_BET_AMOUNT=1000

# Payout multipliers
PAYOUT_NUMBER=14
PAYOUT_COLOR=2
PAYOUT_TYPE=2
