PORT=3000
MONGO_URL=mongodb://127.0.0.1:27017/roulette
JWT_SECRET=your_jwt_secret_key_change_this
CLIENT_URL=http://localhost:5173

# Game Timing (in seconds)
GAME_WAITING_TIME=20
GAME_SPIN_DURATION=5
GAME_RESULT_DURATION=5

# Rate Limiting
# Auth rate limiter (express-rate-limit for HTTP endpoints)
AUTH_RATE_LIMIT_WINDOW_MS=900000 # Time window in ms (default: 15 min)
AUTH_RATE_LIMIT_MAX=1000         # Max requests per window

# Socket rate limiter (for socket events like placeBet, clearBets)
SOCKET_RATE_LIMIT_POINTS=5 # Requests per second

# TimeSync rate limiter (less strict, for clock sync)
TIMESYNC_RATE_LIMIT_POINTS=10 # Requests per second

# Betting Limits
MAX_BET_AMOUNT=1001 # Maximum total bet amount per user per round (in Rs)
# Payout Multipliers
PAYOUT_NUMBER=14
PAYOUT_COLOR=2
PAYOUT_TYPE=2
